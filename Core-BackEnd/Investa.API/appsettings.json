{
  "ConnectionStrings": {
    "DefaultConnection": "Server=DESKTOP-AQR260A;Database=InvestaDb;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=true"
  },
  "Jwt": {
    "Issuer": "Investa",
    "Audience": "Investa.Client",
    "Key": "CHANGE_ME_TO_A_LONG_RANDOM_SECRET_KEY"
