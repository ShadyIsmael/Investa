# -----------------------------------------------------------------
# Investa Project - Master .gitignore
# -----------------------------------------------------------------

# [1] .NET / ASP.NET Core
# -----------------------
bin/
obj/
*.exe
*.dll
*.pdb
*.suo
*.user
*.userosscache
*.sln.docstates
.dotnet/
.vs/
.vscode/
# تجاهل قواعد البيانات المحلية لو موجودة
*.db
*.sqlite

# [2] Flutter / Dart
# -----------------------
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/
# تجاهل ملفات الويب الناتجة عن البناء
/flutter/

# [3] OS & IDE Specific
# -----------------------
.DS_Store
Thumbs.db
*.swp
desktop.ini
.idea/

# [4] Backups & Temporary Folders
# -----------------------
*- Copy/
*.tmp
*.bak
*.log

# [5] Environment Secrets (Very Important)
# -----------------------
.env
appsettings.Development.json
# Firebase service account key — NEVER commit real credentials
**/Secrets/*.json

/flutter/  # ده هيخفي فولدر الـ SDK اللي نزل
!Flutter_Investor/  # علامة التعجب دي بتقول للـ Git: "إظهر الفولدر ده حتى لو فيه شبه من الاسم اللي فوق"

# Ignore generated Flutter build artifacts for the Flutter_Investor app
Flutter_Investor/.dart_tool/
Flutter_Investor/build/
Flutter_Investor/.flutter-plugins
Flutter_Investor/.flutter-plugins-dependencies
Flutter_Investor/.packages
Flutter_Investor/.metadata
Flutter_Investor/android/.gradle/
Flutter_Investor/android/**/.cxx/
Flutter_Investor/android/app/.cxx/
Flutter_Investor/android/app/build/
Flutter_Investor/android/local.properties
Flutter_Investor/ios/Flutter/Generated.xcconfig
Flutter_Investor/ios/Flutter/flutter_export_environment.sh
Flutter_Investor/ios/Flutter/ephemeral/
Flutter_Investor/macos/Flutter/ephemeral/
Flutter_Investor/windows/flutter/ephemeral/
Flutter_Investor/linux/flutter/ephemeral/
# Also ignore plugin symlinks and other ephemeral dirs
Flutter_Investor/**/.plugin_symlinks/

# Ignore generated Flutter build artifacts for the Flutter_Founder app
Flutter_Founder/.dart_tool/
Flutter_Founder/build/
Flutter_Founder/.flutter-plugins
Flutter_Founder/.flutter-plugins-dependencies
Flutter_Founder/.packages
Flutter_Founder/.metadata
Flutter_Founder/android/.gradle/
Flutter_Founder/android/**/.cxx/
Flutter_Founder/android/app/.cxx/
Flutter_Founder/android/app/build/
Flutter_Founder/android/local.properties
Flutter_Founder/ios/Flutter/Generated.xcconfig
Flutter_Founder/ios/Flutter/flutter_export_environment.sh
Flutter_Founder/ios/Flutter/ephemeral/
Flutter_Founder/macos/Flutter/ephemeral/
Flutter_Founder/windows/flutter/ephemeral/
Flutter_Founder/linux/flutter/ephemeral/
# Also ignore plugin symlinks and other ephemeral dirs
Flutter_Founder/**/.plugin_symlinks/

# [6] Generated Pigeon/Dart files
# -----------------------
**/*.g.dart
**/firebase_options.dart

# [7] Temporary test/debug files
# -----------------------
temp_*.json
temp_*.txt
run-output.txt
chat_repository.dart
*.log
flutter-debug.log

# [8] Backend runtime files
# -----------------------
Core-BackEnd/server-stderr.txt
Core-BackEnd/server-stdout.txt
Core-BackEnd/startup-log.txt
Core-BackEnd/backend-debug.log
Core-BackEnd/run.log
Core-BackEnd/migration_output.log
Core-BackEnd/.tmp-*/
Core-BackEnd/TestResults/
Core-BackEnd/scripts/*_results.json
Core-BackEnd/scripts/*_out.txt

# [9] Node modules (web portals)
# -----------------------
node_modules/
dist/
.cache/

# [10] Angular build cache
# -----------------------
.angular/cache/
investa-client-portal/.angular/
investa-admin-portal/.angular/

# [11] Temp SQL diagnostics & output (not source)
# -----------------------
Core-BackEnd/*_results.txt
Core-BackEnd/diagnostic_results.txt
Core-BackEnd/conversion_results.txt
Core-BackEnd/indexes.txt
Core-BackEnd/diagnose_*.sql
Core-BackEnd/check_*.sql
Flutter_Partner/android/.gradle/buildOutputCleanup/buildOutputCleanup.lock
Flutter_Partner/android/.gradle/buildOutputCleanup/buildOutputCleanup.lock
Flutter_Partner/android/.gradle/8.10.2/fileHashes/fileHashes.lock
